<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SpeaLogAnalyzer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SpeaLogAnalyzer.Views"
    Title="SPEA Log Analyzer"
    FlyoutBehavior="Flyout"
    Shell.FlyoutWidth="220">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="120" BackgroundColor="{StaticResource Primary}" Padding="15">
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="SPEA Log"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="Analyzer"
                       FontSize="16"
                       TextColor="{StaticResource Secondary}" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Dashboard" Icon="{x:Null}">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem Title="Sessions" Icon="{x:Null}">
        <ShellContent
            Title="Sessions"
            ContentTemplate="{DataTemplate views:SessionListPage}"
            Route="SessionListPage" />
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <Grid HeightRequest="50" Padding="15">
            <Label Text="BHTC Bulgaria © 2026"
                   VerticalOptions="Center"
                   FontSize="11"
                   TextColor="{StaticResource Gray400}" />
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
