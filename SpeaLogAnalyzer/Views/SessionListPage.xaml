<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SpeaLogAnalyzer.ViewModels"
             xmlns:models="clr-namespace:SpeaLogAnalyzer.Models"
             xmlns:converters="clr-namespace:SpeaLogAnalyzer.Converters"
             x:Class="SpeaLogAnalyzer.Views.SessionListPage"
             x:DataType="vm:SessionListViewModel"
             Title="Sessions"
             Background="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="12">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <Label Text="Test Sessions"
                   FontSize="24"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />

            <Picker Grid.Column="1"
                    Title="Result"
                    ItemsSource="{Binding ResultFilterOptions}"
                    SelectedItem="{Binding SelectedResultFilter}"
                    WidthRequest="120"
                    VerticalOptions="Center" />

            <Button Grid.Column="2"
                    Text="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    HeightRequest="40"
                    Padding="16,0"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Search -->
        <SearchBar Grid.Row="1"
                   Text="{Binding SearchText}"
                   Placeholder="Search by filename, fixture, operator, serial..."
                   BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}" />

        <!-- Session List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredSessions}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding NavigateToDetailCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="{Binding StatusText}"
                           FontSize="16"
                           TextColor="{StaticResource Gray400}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TestSession">
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="{StaticResource Gray200}"
                            StrokeThickness="1"
                            Background="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                            Padding="16"
                            Margin="0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="16">

                            <!-- Result Indicator -->
                            <Border Grid.Column="0"
                                    WidthRequest="8"
                                    HeightRequest="50"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 4"
                                    Background="{Binding OverallResult, Converter={StaticResource ResultToColorConverter}}"
                                    VerticalOptions="Center" />

                            <!-- Session Info -->
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label FontSize="14" FontAttributes="Bold">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} — {1}">
                                            <Binding Path="StartTime" StringFormat="{}{0:yyyy-MM-dd HH:mm}" />
                                            <Binding Path="FixtureId" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding Operator, StringFormat='Operator: {0}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                                <Label Text="{Binding FileName}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray300}" />
                            </VerticalStackLayout>

                            <!-- Board Results -->
                            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Label Text="{Binding PassedBoards, StringFormat='✅ {0}'}" FontSize="13" TextColor="{StaticResource PassColor}" />
                                <Label Text="{Binding FailedBoards, StringFormat='❌ {0}'}" FontSize="13" TextColor="{StaticResource FailColor}" />
                            </HorizontalStackLayout>

                            <!-- Overall Result -->
                            <Border Grid.Column="3"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    Background="{Binding OverallResult, Converter={StaticResource ResultToColorConverter}}"
                                    Padding="12,6"
                                    VerticalOptions="Center">
                                <Label Text="{Binding OverallResultDisplay}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
