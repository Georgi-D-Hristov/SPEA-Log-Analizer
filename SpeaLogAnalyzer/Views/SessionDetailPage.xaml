<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SpeaLogAnalyzer.ViewModels"
             xmlns:models="clr-namespace:SpeaLogAnalyzer.Models"
             x:Class="SpeaLogAnalyzer.Views.SessionDetailPage"
             x:DataType="vm:SessionDetailViewModel"
             Title="Session Detail"
             Background="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20" RowSpacing="12">

        <!-- Back Button + Header -->
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Button Text="← Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontAttributes="Bold"
                    VerticalOptions="Center" />

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Text="{Binding Session.FileName}"
                       FontSize="18"
                       FontAttributes="Bold" />
                <Label FontSize="13" TextColor="{StaticResource Gray400}">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0:yyyy-MM-dd HH:mm:ss} | {1} | {2} | {3}">
                            <Binding Path="Session.StartTime" />
                            <Binding Path="Session.FixtureId" />
                            <Binding Path="Session.Operator" />
                            <Binding Path="Session.Program" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </VerticalStackLayout>
        </Grid>

        <!-- Board Result Cards -->
        <HorizontalStackLayout Grid.Row="1" Spacing="12">
            <CollectionView ItemsSource="{Binding Session.BoardResults}"
                            ItemsLayout="HorizontalList"
                            HeightRequest="80">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BoardResult">
                        <Border StrokeShape="RoundRectangle 10"
                                StrokeThickness="2"
                                Stroke="{Binding Result, Converter={StaticResource ResultToColorConverter}}"
                                Background="{Binding Result, Converter={StaticResource ResultToBackgroundConverter}}"
                                Padding="16,8"
                                Margin="0,0,8,0"
                                WidthRequest="180">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Channel, StringFormat='Board {0}'}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#222222" />
                                <Label Text="{Binding SerialNumber}"
                                       FontSize="11"
                                       TextColor="#555555" />
                                <Label Text="{Binding ResultDisplay}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{Binding Result, Converter={StaticResource ResultToColorConverter}}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </HorizontalStackLayout>

        <!-- Filters Row -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
            <SearchBar Text="{Binding SearchText}"
                       Placeholder="Search component..."
                       BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}" />

            <Picker Grid.Column="1"
                    Title="Channel"
                    ItemsSource="{Binding ChannelFilterOptions}"
                    SelectedItem="{Binding SelectedChannelFilter}"
                    WidthRequest="100" />

            <Picker Grid.Column="2"
                    Title="Result"
                    ItemsSource="{Binding ResultFilterOptions}"
                    SelectedItem="{Binding SelectedResultFilter}"
                    WidthRequest="100" />

            <Picker Grid.Column="3"
                    Title="Category"
                    ItemsSource="{Binding CategoryFilterOptions}"
                    SelectedItem="{Binding SelectedCategoryFilter}"
                    WidthRequest="140" />

            <Label Grid.Column="4"
                   VerticalOptions="Center"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}">
                <Label.Text>
                    <MultiBinding StringFormat="{}Showing {0} | Total: {1} | Failed: {2}">
                        <Binding Path="FilteredMeasurements.Count" />
                        <Binding Path="TotalMeasurements" />
                        <Binding Path="FailedMeasurements" />
                    </MultiBinding>
                </Label.Text>
            </Label>
        </Grid>

        <!-- Measurements Table -->
        <Border Grid.Row="3"
                StrokeShape="RoundRectangle 10"
                Stroke="{StaticResource Gray200}"
                StrokeThickness="1"
                Background="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}">
            <Grid RowDefinitions="Auto,*">

                <!-- Table Header -->
                <Grid ColumnDefinitions="6,50,50,120,60,*,100,100,100,60,60"
                      Padding="0,10,12,10"
                      BackgroundColor="{StaticResource Primary}"
                      ColumnSpacing="4">
                    <BoxView Grid.Column="0" Color="{StaticResource Primary}" WidthRequest="6" />
                    <Label Grid.Column="1" Text="Type" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="2" Text="Ch" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="3" Text="Component" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="4" Text="Result" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="5" Text="Description" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="6" Text="Measured" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="7" Text="Low Limit" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="8" Text="High Limit" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="9" Text="Unit" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    <Label Grid.Column="10" Text="Step" FontSize="11" FontAttributes="Bold" TextColor="White" />
                </Grid>

                <!-- Table Body -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding FilteredMeasurements}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TestMeasurement">
                            <Border StrokeThickness="0"
                                    Padding="0"
                                    Margin="0,0,0,1"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                                <Grid ColumnDefinitions="6,50,50,120,60,*,100,100,100,60,60"
                                      Padding="0,6,12,6"
                                      ColumnSpacing="4">
                                    <!-- Color indicator strip -->
                                    <BoxView Grid.Column="0"
                                             Color="{Binding Result, Converter={StaticResource ResultToColorConverter}}"
                                             WidthRequest="6"
                                             VerticalOptions="Fill" />
                                    <Label Grid.Column="1" Text="{Binding RecordType}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#333333, Dark=#E0E0E0}" />
                                    <Label Grid.Column="2" Text="{Binding Channel}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#333333, Dark=#E0E0E0}" />
                                    <Label Grid.Column="3" Text="{Binding ComponentName}" FontSize="11" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                                    <Label Grid.Column="4"
                                           Text="{Binding ResultDisplay}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{Binding Result, Converter={StaticResource ResultToColorConverter}}" />
                                    <Label Grid.Column="5" Text="{Binding Description}" FontSize="10" LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light=#555555, Dark=#BBBBBB}" />
                                    <Label Grid.Column="6" Text="{Binding MeasuredValue, StringFormat='{0:G5}'}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                                    <Label Grid.Column="7" Text="{Binding LowLimit, StringFormat='{0:G5}'}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                    <Label Grid.Column="8" Text="{Binding HighLimit, StringFormat='{0:G5}'}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                    <Label Grid.Column="9" Text="{Binding Unit}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#333333, Dark=#E0E0E0}" />
                                    <Label Grid.Column="10" Text="{Binding StepNumber}" FontSize="11"
                                           TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
